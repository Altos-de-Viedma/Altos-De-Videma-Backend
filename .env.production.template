# Security Environment Configuration Template
# Updated: 2026-03-25

# Database Configuration (Use strong credentials in production)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=secure_user
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_IN_PRODUCTION
DB_NAME=altos_de_viedma

# JWT Security (Generate strong secrets in production)
JWT_SECRET=CHANGE_THIS_JWT_SECRET_IN_PRODUCTION_MIN_32_CHARS
JWT_EXPIRES_IN=24h

# Application Security
NODE_ENV=production
PORT=3010
CORS_ORIGIN=https://yourdomain.com

# Webhook Security (Use environment-specific URLs)
N8N_URL=https://your-n8n-instance.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security Headers
HELMET_ENABLED=true
TRUST_PROXY=true

# Logging and Monitoring
LOG_LEVEL=warn
ENABLE_AUDIT_LOG=true

# Session Security
SESSION_SECRET=CHANGE_THIS_SESSION_SECRET_IN_PRODUCTION_MIN_32_CHARS
COOKIE_SECURE=true
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=strict

# File Upload Security
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf

# API Security
API_VERSION=v1
ENABLE_API_DOCS=false
API_RATE_LIMIT=true